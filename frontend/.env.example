VITE_CONTRACT_ADDRESS=0xCc539393dD59dEd32d65B537A77515f59B760aa3

# Pinata gateway used to turn a pinned invoice's ipfs:// URI into a clickable/
# fetchable https:// link (browsers can't resolve ipfs:// directly). Defaults
# to the team's dedicated gateway in src/utils/ipfsGateway.js if left unset;
# override here to point at a different gateway subdomain.
VITE_PINATA_GATEWAY=

# Goldsky subgraph GraphQL endpoint. When set, dashboard / disputed / role lists
# read from the indexer instead of the contract's looping view functions.
# Leave empty to fall back to on-chain reads. Get this URL from `goldsky subgraph deploy`.
VITE_GOLDSKY_ENDPOINT=

# Server-side only (read by api/pin-invoice.js, never exposed to the client —
# do NOT prefix with VITE_). Pinata JWT used to pin Create Escrow invoice
# attachments to IPFS. Without it, the invoice uploader's pinning requests
# fail with "Pinning is not configured on the server." Set in the Vercel
# project's environment variables, not just here.
PINATA_JWT=

# Server-side only (read by api/pin-invoice.js and api/request-invoice-key.js
# — do NOT prefix with VITE_). Secret used to deterministically derive the
# AES-256 decryption key for each private-mode invoice (HKDF-SHA256 over this
# secret and the escrow's invoiceHash — no key is ever stored). Without it,
# private-mode invoice pinning fails with "Private invoices are not
# configured on the server." Rotating this secret makes every previously
# pinned private invoice permanently undecryptable — treat it like a
# long-lived signing key, not a rotatable credential. Set in the Vercel
# project's environment variables, not just here.
INVOICE_KEY_SECRET=

# Server-side only (read by api/pin-invoice.js and api/unpin-invoice.js — do
# NOT prefix with VITE_). Signs short-lived capability tokens that authorize
# unpinning one specific just-pinned CID (e.g. an abandoned plaintext
# attachment when Create Escrow switches from public to private mode before
# depositing). Without it, pinning still succeeds, but that cleanup silently
# never happens — Tranche just keeps hosting the orphaned file. Deliberately
# a different secret from INVOICE_KEY_SECRET: this one authorizes a
# destructive action on Tranche's storage, INVOICE_KEY_SECRET only derives a
# read-only decryption key, and a leak of one shouldn't compromise the
# other. Set in the Vercel project's environment variables, not just here.
UNPIN_TOKEN_SECRET=
