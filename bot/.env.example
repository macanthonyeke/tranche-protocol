# ---------------------------------------------------------------------------
# TrancheProtocol Telegram bot — env template
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# Telegram bot token issued by @BotFather
TELEGRAM_BOT_TOKEN=

# Arc testnet JSON-RPC endpoint
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Arc testnet chain id (set after confirming with the Arc team)
ARC_CHAIN_ID=

# Deployed TrancheProtocol address — update after every fresh deploy (npm run full-gas in deploy/)
CONTRACT_ADDRESS=

# Numeric Telegram user id of the address holding ARBITER_ROLE.
# Send /start to @userinfobot in Telegram to look up an id.
ARBITER_TELEGRAM_ID=

# Optional cron expression for the reminder scan (default: every hour at :00)
# REMINDER_CRON=0 * * * *

# Optional: enable verbose debug logging
# DEBUG=1
