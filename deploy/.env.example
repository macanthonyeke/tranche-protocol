# Circle API credentials
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here

# Your existing Circle developer-controlled wallet
# This is the wallet ID from Circle console, NOT the address
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DEPLOYER_WALLET_ID=your_wallet_id_here

# The on-chain address of the deployer wallet
# Used to confirm role ownership and update downstream config
DEPLOYER_ADDRESS=0xYourDeployerWalletAddress

# Who gets ARBITER_ROLE at deployment and after setup
# Can be same as deployer for now, change later via role management
ARBITER_ADDRESS=0xYourArbiterAddress

# Who gets PAUSER_ROLE at deployment and after setup
PAUSER_ADDRESS=0xYourPauserAddress

# Who gets DOMAIN_MANAGER_ROLE at deployment
# Must be different from DEPLOYER_ADDRESS
DOMAIN_MANAGER_ADDRESS=0xYourDomainManagerAddress

# Private key for DOMAIN_MANAGER_ADDRESS
# Used only for domain-manager actions such as addSupportedDomain
DOMAIN_MANAGER_PRIVATE_KEY=0xyour_domain_manager_private_key_here

# Protocol treasury -- where the 1.99% fee goes
PROTOCOL_TREASURY=0xYourTreasuryAddress

# Arc Testnet RPC (for verification reads after deploy)
ARC_RPC_URL=https://rpc.testnet.arc.network

# After deployment, this gets filled in automatically by deploy.js
# CONTRACT_ADDRESS=
